{
  "manifest_version": 3,
  "name": "WhatsApp Web Transcriptor",
  "version": "1.0.0",
  "description": "Detecta audios en WhatsApp Web y muestra transcripcion + resumen automaticamente.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page_probe.js"
      ],
      "matches": [
        "https://web.whatsapp.com/*"
      ]
    }
  ]
}
